<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thêm các điểm vuốt. Kéo để sắp xếp thứ tự thực hiện."
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Chưa có điểm vuốt nào\nNhấn + để thêm"
        android:textColor="@color/text_hint"
        android:textSize="16sp"
        android:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSwipes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btnAddSwipe"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="+ Thêm điểm vuốt"
        android:textColor="@color/white"
        android:backgroundTint="@color/accent_orange"
        android:layout_marginTop="12dp"
        style="@style/Widget.MaterialComponents.Button" />

    <Button
        android:id="@+id/btnSaveSwipes"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="💾 Lưu tất cả"
        android:textColor="@color/white"
        android:backgroundTint="@color/accent_blue"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        style="@style/Widget.MaterialComponents.Button" />

</LinearLayout>
