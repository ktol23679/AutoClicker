<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nhãn (tên điểm vuốt)"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="VD: Vuốt lên 1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Start X / Y -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="X bắt đầu" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etStartX"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="numberDecimal" android:hint="200" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Y bắt đầu" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etStartY"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="numberDecimal" android:hint="800" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- End X / Y -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="X kết thúc" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etEndX"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="numberDecimal" android:hint="800" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Y kết thúc" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etEndY"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="numberDecimal" android:hint="800" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Duration & Delay -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="4dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Thời gian vuốt (ms)" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etDuration"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="number" android:hint="300" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Độ trễ trước khi vuốt (ms)" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etDelay"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="number" android:hint="500" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
