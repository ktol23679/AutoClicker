<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AutoClicker" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryVariant">@color/surface_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_green</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/surface_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="actionBarStyle">@style/AutoClickerActionBar</item>
        <item name="toolbarStyle">@style/AutoClickerToolbar</item>
        <item name="materialAlertDialogTheme">@style/AutoClickerDialog</item>
    </style>

    <style name="AutoClickerActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/surface_dark</item>
        <item name="titleTextStyle">@style/AutoClickerActionBarTitle</item>
    </style>

    <style name="AutoClickerActionBarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="AutoClickerToolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/surface_dark</item>
        <item name="titleTextColor">@color/text_primary</item>
    </style>

    <style name="AutoClickerDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:background">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>
</resources>
